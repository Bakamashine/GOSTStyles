\newcommand{\image}[2]{
	\begin{figure}[H]
		\centering
		\includegraphics[width=0.9\linewidth]{#1}
		\caption{#2}
		\label{fig:placeholder}
	\end{figure}
}

\newcommand{\smallImage}[2]{
	\begin{figure}[H]
		\centering
		\includegraphics[width=0.5\linewidth]{#1}
		\caption{#2}
		\label{fig:placeholder}
	\end{figure}
}

\newcommand{\imageWithoutCaption}[1] {
	\begin{figure}[H]
		\centering
		\includegraphics[width=0.5\linewidth]{#1}
	\end{figure}
}
