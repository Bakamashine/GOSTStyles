\AtBeginEnvironment{Verbatim}{\fontsize{9}{11}\selectfont\ttfamily}
\BeforeBeginEnvironment{Verbatim}{\par}
\AfterEndEnvironment{Verbatim}{\par}


\newcommand{\titleOne}[1]{%
	{\centering\fontsize{22}{26}\selectfont\bfseries\MakeUppercase{#1}\par}%
}

\newcommand{\MyVerbatim}[1]{%
	\begin{multicols}{2}%
	{\par\fontsize{7}{9}\selectfont\VerbatimInput[breaklines=true]{#1}\par}%
	\end{multicols}%
}

\newcommand{\MyVerbatimLarge}[1]{%
	\begin{multicols}{2}%
	{\par\fontsize{5}{7}\selectfont\VerbatimInput[breaklines=true,obeytabs,tabsize=1]{#1}\par}%
	\end{multicols}%
}

